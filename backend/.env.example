# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB
MONGODB_URI=mongodb://localhost:27017/flash-trafood

# PostgreSQL (alternativa)
# DATABASE_URL=postgresql://user:password@localhost:5432/flash-trafood

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-produccion
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=tu-refresh-secreto-cambiar-en-produccion
JWT_REFRESH_EXPIRE=30d

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:19000,http://192.168.1.100:19000

# ==========================================
# SOCKET.IO CONFIGURATION
# ==========================================
SOCKET_CORS_ORIGIN=http://localhost:19000

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-contraseña-app-especifica
SMTP_FROM_NAME=Flash Trafood

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Google Maps API Key
GOOGLE_MAPS_API_KEY=tu-google-maps-api-key

# Firebase Configuration (notificaciones push)
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_PRIVATE_KEY=tu-private-key
FIREBASE_CLIENT_EMAIL=tu-client-email

# ==========================================
# APP CONFIGURATION
# ==========================================
APP_NAME=Flash Trafood
APP_VERSION=1.0.0
LOG_LEVEL=debug
